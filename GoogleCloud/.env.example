###############################################################################
# General configuration
###############################################################################

PROJECT_ID=$(gcloud config get-value project 2>/dev/null)
IMAGE='gcr.io/STRAST_UPM/base_service_js:latest'
PREFIX='exp'
WAIT_SECONDS=60

